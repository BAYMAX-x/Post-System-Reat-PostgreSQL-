# Environment Configuration for Lanka Fresh POS Backend
# Copy this file to .env and fill in your values

# PostgreSQL Connection
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/lankafresh_pos"

# Server Config
PORT=3001
HOST=0.0.0.0

# Store Info (used in receipts)
STORE_NAME="Lanka Fresh Market"
STORE_ADDRESS="No. 45, Galle Road, Colombo 03"
STORE_TEL="+94 11 2345 678"
STORE_VAT_REG="123456789-7000"
