// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           Int      @id @default(autoincrement())
  barcode      String   @unique
  sku          String   @unique
  name         String
  nameSi       String?
  category     String
  unit         String   @default("Unit")
  price        Decimal  @db.Decimal(10, 2)
  costPrice    Decimal? @db.Decimal(10, 2)
  stock        Int      @default(0)
  minStock     Int      @default(10)
  imageUrl     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactionItems TransactionItem[]

  @@map("products")
}

model Customer {
  id             String   @id @default(cuid())
  name           String
  phone          String?
  email          String?
  type           String   @default("Regular") // Regular, VIP, Wholesale
  loyaltyPoints  Int      @default(0)
  totalSpent     Decimal  @default(0) @db.Decimal(12, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions   Transaction[]

  @@map("customers")
}

model Transaction {
  id             String   @id @default(cuid())
  billNo         String   @unique
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  subtotal       Decimal  @db.Decimal(12, 2)
  discountType   String?  // percent, amount
  discountValue  Decimal? @db.Decimal(10, 2)
  discountAmount Decimal  @default(0) @db.Decimal(12, 2)
  taxRate        Decimal  @default(0.08) @db.Decimal(5, 4)
  taxAmount      Decimal  @db.Decimal(12, 2)
  total          Decimal  @db.Decimal(12, 2)
  paymentMethod  String   // cash, card, qr, mobile
  cashReceived   Decimal? @db.Decimal(12, 2)
  changeGiven    Decimal? @db.Decimal(12, 2)
  cashierId      String?
  registerId     String   @default("REG-01")
  notes          String?
  createdAt      DateTime @default(now())

  items          TransactionItem[]

  @@map("transactions")
}

model TransactionItem {
  id            Int         @id @default(autoincrement())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     Int
  product       Product     @relation(fields: [productId], references: [id])
  productName   String      // snapshot at time of sale
  price         Decimal     @db.Decimal(10, 2)
  quantity      Int
  subtotal      Decimal     @db.Decimal(12, 2)

  @@map("transaction_items")
}

model StoreSettings {
  id            Int    @id @default(1)
  storeName     String @default("Lanka Fresh Market")
  storeAddress  String @default("")
  storeTel      String @default("")
  vatRegNo      String @default("")
  taxRate       Decimal @default(0.08) @db.Decimal(5, 4)
  currencyCode  String @default("LKR")
  receiptFooter String @default("Thank you for shopping with us!")
  updatedAt     DateTime @updatedAt

  @@map("store_settings")
}
